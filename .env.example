# Word Laboratory — LLM Meaning Analysis (server-side only)
#
# Set these in your Vercel project (Settings → Environment Variables), NOT in the
# client. The key is used only by the /api/analyze serverless function and is
# never exposed to the browser. Without a key, the app runs on its self-contained
# deterministic engine.

# Your Anthropic API key. Required to enable LLM meaning analysis.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: which model does the meaning analysis. Defaults to claude-opus-4-8.
# Cheaper options for this task: claude-sonnet-5 or claude-haiku-4-5.
# WORDLAB_MODEL=claude-sonnet-5
